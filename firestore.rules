rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Config: public read, admin write (checks adminKey field in request)
    match /config/{docId} {
      allow read: if true;

      // Allow all config writes if request has valid admin key
      allow write: if request.resource.data.keys().hasAny(['_adminKey'])
                   && request.resource.data._adminKey == 'pixellakh2024';

      // Golden pixel claims (winner update only when active and no winner)
      allow update: if docId == 'goldenPixel'
                    && resource.data.active == true
                    && resource.data.winner == null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['winner', 'active'])
                    && request.resource.data.winner is map
                    && request.resource.data.active == false;
    }

    // Winners history
    match /winners/{winnerId} {
      allow read: if true;
      // Allow admin writes with key
      allow write: if request.resource.data.keys().hasAny(['_adminKey'])
                   && request.resource.data._adminKey == 'pixellakh2024';
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isValidAd();
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrl'])
                    && request.resource.data.imageUrl is string;
      // Allow admin delete with special doc
      allow delete: if false;
    }

    function isValidAd() {
      let data = request.resource.data;
      return data.keys().hasAll(['bx', 'by', 'bw', 'bh', 'color', 'label', 'url', 'owner', 'imageUrl', 'createdAt'])
        && data.bx is int && data.by is int
        && data.bw is int && data.bh is int
        && data.bx >= 0 && data.by >= 0
        && data.bw > 0 && data.bh > 0
        && data.bx + data.bw <= 1000
        && data.by + data.bh <= 1000
        && data.label is string && data.label.size() > 0 && data.label.size() <= 50
        && data.owner is string && data.owner.size() <= 50
        && data.url is string && data.url.size() <= 500
        && data.color is string && data.color.size() <= 10
        && data.createdAt == request.time;
    }
  }
}
